generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASEAVICOLA_DATABASE_URL")
}

model Cliente {
  id          String       @id @default(cuid())
  nombre      String
  telefono    String?
  direccion   String?
  createdAt   DateTime     @default(now())
  movimientos Movimiento[]
}

enum TipoCarton {
  PEQUENO
  MEDIANO
  GRANDE
  JUMBO
}

model Movimiento {
  id         String      @id @default(cuid())
  clienteId  String
  cliente    Cliente     @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  tipo       String // "ENTREGA" | "PAGO"
  fecha      DateTime
  cartones   Int?
  tipoCarton TipoCarton?
  precioUnit Float?
  monto      Float?
  notas      String?
  createdAt  DateTime    @default(now())
}

model Gasto {
  id          String   @id @default(cuid())
  fecha       DateTime
  categoria   String
  descripcion String?
  monto       Float
  createdAt   DateTime @default(now())
}

model Bajada {
  id              String   @id @default(cuid())
  fecha           DateTime
  cartonesPequeno Int      @default(0)
  cartonesMediano Int      @default(0)
  cartonesGrande  Int      @default(0)
  cartonesJumbo   Int      @default(0)
  notas           String?
  createdAt       DateTime @default(now())
}
